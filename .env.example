# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN
CLIENT_ID=YOUR_BOT_CLIENT_ID
GUILD_ID=YOUR_GUILD_ID

# ─── Сенат Штата Сан-Андреас ─────────────────────────────────────────────────
# Форум-канал для законопроектов (Forum Channel)
SENATE_CHANNEL_ID=FORUM_CHANNEL_ID
BILLS_FORUM_CHANNEL_ID=FORUM_CHANNEL_ID
# Канал для создания заседаний (текстовый)
SENATE_MEETING_CHANNEL_ID=TEXT_CHANNEL_ID
# Канал главного сообщения сената (setup_senate)
SENATE_MAIN_CHANNEL_ID=TEXT_CHANNEL_ID

# Канал для замены сенатора
SENATOR_REPLACEMENT_CHANNEL_ID=CHANNEL

# ─── Роли ────────────────────────────────────────────────────────────────────
# Роль для упоминания при создании заседания
SENATE_MENTION_ROLE_ID=ROLE_ID
# Сенатор (с правом голоса)
SENATOR_ROLE_ID=ROLE_ID
# Сенатор (без права голоса)
SENATOR_NO_VOTE_ROLE_ID=ROLE_ID
# Председатель (Спикер) Сената
CHAIRMAN_ROLE_ID=ROLE_ID
# Вице-председатель Сената
VICE_CHAIRMAN_ROLE_ID=ROLE_ID
# Федеральное правительство (ID пользователей через запятую)
FEDERAL_GOVERNMENT_USER_ID=USER_ID_1,USER_ID_2
# Роль Федерального правительства
FEDERAL_GOVERNMENT_ROLE_ID=ROLE_ID

# ─── Администраторы ───────────────────────────────────────────────────────────
ADMIN_ROLE_SEND_ID=ROLE_ID_1,ROLE_ID_2
SYSADMIN_ROLE_ID=ROLE_ID_1,ROLE_ID_2

# ─── Теги форума ─────────────────────────────────────────────────────────────
FORUM_TAG_ON_REVIEW=TAG_ID
FORUM_TAG_APPROVED=TAG_ID
FORUM_TAG_REJECTED=TAG_ID
FORUM_TAG_NOT_APPROVED=TAG_ID
FORUM_TAG_SIGNED=TAG_ID
FORUM_TAG_VETOED=TAG_ID

# ─── База данных SQLite ────────────────────────────────────────────────────────
DB_PATH=./senate.db

# ─── Состав Сената ────────────────────────────────────────────────────────────
# Список сенаторов хранится в SQLite и управляется через Discord.
